TIKO_ENVIRONMENT=local
TIKO_SAFETY_MODE=simulation_only
TIKO_ALLOW_PRIVATE_EXCHANGE_METHODS=false
TIKO_ALLOW_TRADING_CREDENTIALS=false

# Optional OpenRouter settings for simulated agent evaluation.
# Use a local .env file for real values. Do not commit secrets.
TIKO_OPENROUTER_API_KEY=your-openrouter-market-research-key
TIKO_OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free
TIKO_OPENROUTER_TIMEOUT_SECONDS=60
TIKO_OPENROUTER_TEMPERATURE=0.1
TIKO_OPENROUTER_MAX_TOKENS=4096
